[ext_resource type="Script" path="res://scripts/club.gd" id="1_club"]

[resource]
script = ExtResource("1_club")
name = "Flamengo"
period = "1980-1983"
description = "O Flamengo de Zico, Adílio e Andrade. Tricampeão brasileiro e campeão da Libertadores e do Mundial de 1981. Considerado por muitos o melhor time da história do futebol brasileiro."
